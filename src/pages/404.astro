---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | Patrick Rall" description="Page not found.">
  <main class="main-container">
    <div class="content-wrapper animate-appear">
      <div class="header-section">
        <p class="title-text">Not Found</p>
        <p class="header-index">[ 404 ]</p>
      </div>

      <div class="body-section">
        <p class="body-text">ENOENT.</p>
      </div>

      <nav class="nav-section">
        <a href="/" class="nav-back">← home</a>
      </nav>
    </div>
  </main>
</Layout>

<style>
  .main-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 0 16px;
  }

  .content-wrapper {
    width: 100%;
    max-width: 520px;
  }

  .header-section {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 10px;
    padding-bottom: 16px;
  }

  .title-text {
    font-family: 'ABC Marist Unlicensed Trial Book', sans-serif;
    font-size: 20px;
    letter-spacing: -0.03em;
    line-height: 24px;
  }

  .header-index {
    flex: 1;
    text-align: right;
    font-family: 'ABC Marist Unlicensed Trial Book', sans-serif;
    font-size: 12px;
    letter-spacing: 0.015em;
    line-height: 14px;
    color: rgb(59, 61, 65);
  }

  .body-section {
    margin-bottom: 24px;
  }

  .body-text {
    font-family: 'ABC Marist Unlicensed Trial Book', sans-serif;
    font-size: 15px;
    letter-spacing: -0.01em;
    line-height: 17px;
    font-weight: 300;
    color: rgb(59, 61, 65);
  }

  .nav-back {
    font-family: 'ABC Marist Unlicensed Trial Book', sans-serif;
    font-size: 12px;
    letter-spacing: -0.01em;
    line-height: 14px;
    color: rgb(59, 61, 65);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-back:hover {
    color: rgb(0, 0, 0);
  }
</style>
