---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  width?: string;
}

const { src, alt = '', caption, width } = Astro.props;
---

<figure class="post-figure" style={width ? `max-width: ${width};` : ''}>
  <img src={src} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .post-figure {
    margin: 20px 0;
    display: block;
  }

  .post-figure img {
    width: 100%;
    display: block;
    border: 0.5px solid var(--border-color);
  }

  .post-figure figcaption {
    font-family: 'ABC Marist Unlicensed Trial Book', sans-serif;
    font-size: 11px;
    letter-spacing: -0.01em;
    line-height: 15px;
    color: rgb(140, 143, 148);
    margin-top: 6px;
    padding-left: 1px;
  }
</style>
