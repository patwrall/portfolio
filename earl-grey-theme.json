{
  "name": "earl-grey",
  "type": "light",
  "colors": {
    "editor.background": "#FFFFFF",
    "editor.foreground": "#3B3D41"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8C8F94",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#3B3D41",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#C72E4B"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7445C0"
      }
    },
    {
      "scope": [
        "storage.type",
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#2162A9"
      }
    },
    {
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#3B3D41"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#0F8B7D"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#3B3D41"
      }
    }
  ]
}
